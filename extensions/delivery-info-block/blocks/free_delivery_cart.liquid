{%- assign s = shop.metafields.delivery_rules.settings.value | parse_json -%}
{%- if s.fd_enabled -%}
<div class="dib-fd-bar" data-dm-target data-dm-state="init" data-dm-celebrated="" data-dib-liquid-block style="display:flex;flex-direction:column;gap:8px;padding:12px 16px;background:{{ s.fd_bar_bg_color | default:'#f9fafb' }};border-radius:{{ s.fd_bar_border_radius | default:8 }}px;border:{{ s.fd_bar_border_width | default:0 }}px solid {{ s.fd_bar_border_color | default:'#e5e7eb' }};font-size:14px;line-height:1.4;width:100%;box-sizing:border-box;margin:12px 0;">
<div class="dib-fd-message" data-dm-message style="text-align:center;font-weight:500;color:{{ s.fd_bar_text_color | default:'#374151' }};min-height:20px;"><div class="dib-fd-skeleton-text"></div></div>
{%- unless s.fd_show_progress_bar == false -%}<div class="dib-fd-progress" data-dm-progress data-bg="{{ s.fd_progress_bar_bg | default:'#e5e7eb' }}" data-fg="{{ s.fd_progress_bar_color | default:'#22c55e' }}" style="height:8px;border-radius:4px;background:{{ s.fd_progress_bar_bg | default:'#e5e7eb' }};"></div>{%- endunless -%}
</div>
{%- endif -%}
{% schema %}
{"name":"Free Delivery Bar (Cart)","target":"section","settings":[]}
{% endschema %}
