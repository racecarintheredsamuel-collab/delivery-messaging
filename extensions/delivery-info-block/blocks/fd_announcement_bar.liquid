{%- assign global_settings_json = shop.metafields.delivery_rules.settings.value -%}
{%- assign global_settings = nil -%}
{%- if global_settings_json != blank -%}
  {%- assign global_settings = global_settings_json | parse_json -%}{%- assign gs = global_settings -%}
{%- endif -%}
{%- unless gs.fd_show_announcement_bar == false -%}
{%- assign fd_threshold = 5000 -%}
{%- assign fd_exclusion_rules = '' -%}
{%- assign fd_exclude_tags = '' -%}
{%- assign fd_exclude_handles = '' -%}
{%- capture fd_progress_message -%}Spend {remaining} more for free delivery{%- endcapture -%}
{%- capture fd_unlocked_message -%}You've unlocked free delivery!{%- endcapture -%}
{%- assign fd_empty_message = '' -%}
{%- assign fd_excluded_message = '' -%}
{%- assign fd_bg_color = '#1f2937' -%}
{%- assign fd_text_color = '#ffffff' -%}
{%- assign fd_text_size = 14 -%}
{%- assign fd_bar_height = 'comfortable' -%}
{%- assign fd_progress_duration = 5 -%}
{%- assign fd_unlocked_duration = 5 -%}
{%- assign fd_empty_duration = 5 -%}
{%- assign fd_excluded_duration = 5 -%}
{%- assign fd_additional1_message = '' -%}
{%- assign fd_additional1_duration = 5 -%}
{%- assign fd_additional2_message = '' -%}
{%- assign fd_additional2_duration = 5 -%}
{%- assign fd_additional3_message = '' -%}
{%- assign fd_additional3_duration = 5 -%}
{%- assign fd_content_max_width = '' -%}
{%- assign fd_multi_match_message = '' -%}
{%- assign fd_util_left_icon = '' -%}
{%- assign fd_util_left_label = '' -%}
{%- assign fd_util_left_url = '' -%}
{%- assign fd_util_left_target = '_blank' -%}
{%- assign fd_util_right_icon = '' -%}
{%- assign fd_util_right_label = '' -%}
{%- assign fd_util_right_url = '' -%}
{%- assign fd_util_right_target = '_blank' -%}
{%- assign fd_util_mobile_mode = 'hide' -%}

{%- if gs -%}{%- assign fd_threshold = gs.fd_threshold | default: fd_threshold -%}{%- assign fd_exclusion_rules = gs.fd_exclusion_rules | default: '' | json -%}{%- assign fd_multi_match_message = gs.fd_exclusion_multi_match_message | default: fd_multi_match_message -%}{%- assign fd_exclude_tags = gs.fd_exclude_tags | default: '' | json -%}{%- assign fd_exclude_handles = gs.fd_exclude_handles | default: '' | json -%}{%- assign fd_progress_message = gs.fd_announcement_progress_message | default: fd_progress_message -%}{%- assign fd_unlocked_message = gs.fd_announcement_unlocked_message | default: fd_unlocked_message -%}{%- assign fd_empty_message = gs.fd_announcement_empty_message | default: fd_empty_message -%}{%- assign fd_excluded_message = gs.fd_announcement_excluded_message | default: fd_excluded_message -%}{%- assign fd_bg_color = gs.fd_announcement_bg_color | default: fd_bg_color -%}{%- assign fd_text_color = gs.fd_announcement_text_color | default: fd_text_color -%}{%- assign fd_text_size = gs.fd_announcement_text_size | default: fd_text_size -%}{%- assign fd_bar_height = gs.fd_announcement_bar_height | default: fd_bar_height -%}{%- assign fd_progress_duration = gs.fd_announcement_progress_duration | default: fd_progress_duration -%}{%- assign fd_unlocked_duration = gs.fd_announcement_unlocked_duration | default: fd_unlocked_duration -%}{%- assign fd_empty_duration = gs.fd_announcement_empty_duration | default: fd_empty_duration -%}{%- assign fd_excluded_duration = gs.fd_announcement_excluded_duration | default: fd_excluded_duration -%}{%- assign fd_additional1_message = gs.fd_announcement_additional1_message | default: fd_additional1_message -%}{%- assign fd_additional1_duration = gs.fd_announcement_additional1_duration | default: fd_additional1_duration -%}{%- assign fd_additional2_message = gs.fd_announcement_additional2_message | default: fd_additional2_message -%}{%- assign fd_additional2_duration = gs.fd_announcement_additional2_duration | default: fd_additional2_duration -%}{%- assign fd_additional3_message = gs.fd_announcement_additional3_message | default: fd_additional3_message -%}{%- assign fd_additional3_duration = gs.fd_announcement_additional3_duration | default: fd_additional3_duration -%}{%- assign fd_content_max_width = gs.fd_announcement_content_max_width | default: fd_content_max_width -%}{%- assign fd_util_left_icon = gs.fd_utility_left_icon | default: fd_util_left_icon -%}{%- assign fd_util_left_label = gs.fd_utility_left_label | default: fd_util_left_label -%}{%- assign fd_util_left_url = gs.fd_utility_left_url | default: fd_util_left_url -%}{%- assign fd_util_left_target = gs.fd_utility_left_target | default: fd_util_left_target -%}{%- assign fd_util_right_icon = gs.fd_utility_right_icon | default: fd_util_right_icon -%}{%- assign fd_util_right_label = gs.fd_utility_right_label | default: fd_util_right_label -%}{%- assign fd_util_right_url = gs.fd_utility_right_url | default: fd_util_right_url -%}{%- assign fd_util_right_target = gs.fd_utility_right_target | default: fd_util_right_target -%}{%- assign fd_util_mobile_mode = gs.fd_utility_mobile_mode | default: fd_util_mobile_mode -%}{%- endif -%}
{%- if gs.fd_additional_messages_enabled == false -%}{%- assign fd_additional1_message = '' -%}{%- assign fd_additional2_message = '' -%}{%- assign fd_additional3_message = '' -%}{%- endif -%}
{%- if gs.fd_utility_links_enabled == false -%}{%- assign fd_util_left_icon = '' -%}{%- assign fd_util_left_label = '' -%}{%- assign fd_util_right_icon = '' -%}{%- assign fd_util_right_label = '' -%}{%- endif -%}
{%- if fd_empty_message == blank and fd_additional1_message == blank and fd_additional2_message == blank and fd_additional3_message == blank -%}{%- assign fd_empty_message = 'Free delivery on orders over {threshold}' -%}{%- endif -%}
{%- if fd_excluded_message == blank -%}{%- assign fd_excluded_message = "Some items aren't eligible for free delivery" -%}{%- endif -%}
{%- assign ct = gs.cutoff_time | default: '14:00' -%}
{%- assign cts = gs.cutoff_time_sat | default: '' -%}
{%- assign ctu = gs.cutoff_time_sun | default: '' -%}
{%- assign cd = gs.closed_days | join: ',' | default: '' -%}
{%- assign bh = gs.bank_holiday_country | default: '' -%}
{%- assign ch = '' -%}{%- if gs.custom_holidays != blank -%}{%- for h in gs.custom_holidays -%}{%- if ch != '' -%}{%- assign ch = ch | append: ',' -%}{%- endif -%}{%- assign ch = ch | append: h.date -%}{%- endfor -%}{%- endif -%}

{%- assign text_size_px = fd_text_size | default: 14 -%}
{%- assign line_height_px = text_size_px | times: 1.4 | ceil -%}
{%- case fd_bar_height -%}{%- when 'compact' -%}{%- assign bar_padding = '6px 16px' -%}{%- assign pad_v = 6 -%}{%- when 'standard' -%}{%- assign bar_padding = '10px 16px' -%}{%- assign pad_v = 10 -%}{%- when 'spacious' -%}{%- assign bar_padding = '18px 16px' -%}{%- assign pad_v = 18 -%}{%- else -%}{%- assign bar_padding = '14px 16px' -%}{%- assign pad_v = 14 -%}{%- endcase -%}
{%- assign bar_total_height = pad_v | times: 2 | plus: line_height_px -%}
{%- assign content_max_px = fd_content_max_width | default: 800 -%}{%- assign content_max_vw = content_max_px | times: 100.0 | divided_by: 1920.0 | round: 2 -%}{%- assign content_max_mobile = gs.fd_announcement_content_max_width_mobile | default: 90 -%}
{%- if gs.fd_use_custom_link_styling -%}{%- assign lc = gs.fd_announcement_link_color | default: fd_text_color -%}{%- assign ld = gs.fd_announcement_link_decoration | default: 'none' -%}{%- assign lt = gs.fd_announcement_link_thickness | default: '1px' -%}{%- assign lhc = gs.fd_announcement_link_hover_color | default: '#e5e7eb' -%}{%- assign lhd = gs.fd_announcement_link_hover_decoration | default: 'underline' -%}{%- assign lht = gs.fd_announcement_link_hover_thickness | default: '2px' -%}{%- assign lho = gs.fd_announcement_link_hover_opacity | default: 1 -%}{%- else -%}{%- assign lc = gs.link_color | default: '#2563eb' -%}{%- assign ld = gs.link_decoration | default: 'underline' -%}{%- assign lt = gs.link_thickness | default: '1px' -%}{%- assign lhc = gs.link_hover_color | default: '#1d4ed8' -%}{%- assign lhd = gs.link_hover_decoration | default: 'underline' -%}{%- assign lht = gs.link_hover_thickness | default: '2px' -%}{%- assign lho = gs.link_hover_opacity | default: 1 -%}{%- endif -%}
<style>.dfa{height:{{ bar_total_height }}px;contain:layout;display:flex;align-items:center}.dfa.dfcl{animation:dap .4s ease-out!important}@keyframes dap{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.02);opacity:.9}}.dfi{display:flex;align-items:center;justify-content:center;width:100%;min-height:{{ line_height_px }}px;position:relative}.dfs{position:absolute;display:flex;align-items:center}.dfs-l{left:0}.dfs-r{right:0}.dfc{display:flex;align-items:center;justify-content:space-between;gap:8px;width:100%}.dchv{background:none;border:none;color:inherit;cursor:pointer;padding:8px;opacity:.6;transition:opacity .15s;display:none;flex-shrink:0}.dchv:hover{opacity:1}.dchv svg{width:12px;height:12px;display:block}.dfa.dfhm .dchv{display:block}.dfa:not(.dfhm) .dfc{justify-content:center}.dfmw{display:inline-block;opacity:0;transition:opacity .15s;min-height:{{ line_height_px }}px;vertical-align:middle}.dfu{display:flex;align-items:center;gap:4px;font-size:inherit;line-height:inherit;white-space:nowrap;transition:color .15s,opacity .15s}.dfa a.dfu,.dfa a.dfu:link,.dfa a.dfu:visited{color:var(--uc)!important;text-decoration:var(--ud)!important;text-decoration-thickness:var(--ut)!important}.dfa a.dfu:hover{color:var(--hc)!important;text-decoration:var(--hd)!important;text-decoration-thickness:var(--ht)!important;opacity:var(--ho)}.dfu svg{width:1em;height:1em;flex-shrink:0}@media(max-width:767px){.dfc{max-width:{{ content_max_mobile }}%!important}.dfm-h .dfs{display:none}.dfm-i .dfu span{display:none}.dfm-il .dfs-r{left:1.5em;right:auto}.dfm-il .dfu span{display:none}.dfm-ir .dfs-l{left:auto;right:1.5em}.dfm-ir .dfu span{display:none}}</style>

<div class="dfa{% if fd_util_mobile_mode == 'hide' %} dfm-h{% elsif fd_util_mobile_mode == 'icons' %} dfm-i{% elsif fd_util_mobile_mode == 'icons_left' %} dfm-il{% elsif fd_util_mobile_mode == 'icons_right' %} dfm-ir{% endif %}"
  style="padding:{{ bar_padding }};background:{{ fd_bg_color }};color:{{ fd_text_color }};font-size:{{ text_size_px }}px;line-height:1.4;text-align:center;width:100%;box-sizing:border-box;--uc:{{ lc }};--ud:{{ ld }};--ut:{{ lt }};--hc:{{ lhc }};--hd:{{ lhd }};--ht:{{ lht }};--ho:{{ lho }}"
  data-dm-target
  data-dm-no-hide
  data-dm-cycling
  data-threshold="{{ fd_threshold }}"
  data-currency="{{ shop.currency }}"
  data-locale="{{ request.locale.iso_code }}"
  data-progress-message="{{ fd_progress_message | escape }}"
  data-unlocked-message="{{ fd_unlocked_message | escape }}"
  data-empty-message="{{ fd_empty_message | escape }}"
  data-excluded-message="{{ fd_excluded_message | escape }}"
  data-has-empty-message="{{ fd_empty_message | size | at_least: 1 }}"
  data-has-excluded-message="{{ fd_excluded_message | size | at_least: 1 }}"
  data-exclusion-rules="{{ fd_exclusion_rules | escape }}"
  data-exclude-tags="{{ fd_exclude_tags | escape }}"
  data-exclude-handles="{{ fd_exclude_handles | escape }}"
  data-progress-duration="{{ fd_progress_duration }}"
  data-unlocked-duration="{{ fd_unlocked_duration }}"
  data-empty-duration="{{ fd_empty_duration }}"
  data-excluded-duration="{{ fd_excluded_duration }}"
  data-additional1-message="{{ fd_additional1_message | escape }}"
  data-additional1-duration="{{ fd_additional1_duration }}"
  data-additional2-message="{{ fd_additional2_message | escape }}"
  data-additional2-duration="{{ fd_additional2_duration }}"
  data-additional3-message="{{ fd_additional3_message | escape }}"
  data-additional3-duration="{{ fd_additional3_duration }}"
  data-multi-match-message="{{ fd_multi_match_message | escape }}"
>
  <span class="dcc" style="display:none" data-shop-offset="{{ 'now' | date: '%z' }}" data-cutoff="{{ ct }}" data-cutoff-sat="{{ cts }}" data-cutoff-sun="{{ ctu }}" data-closed-days="{{ cd }}" data-bank-holiday-country="{{ bh }}" data-custom-holidays="{{ ch }}" data-link-color="{{ lc }}" data-link-decoration="{{ ld }}" data-link-hover-color="{{ lhc }}" data-link-hover-decoration="{{ lhd }}" data-link-hover-opacity="{{ lho }}" data-link-thickness="{{ lt }}" data-link-hover-thickness="{{ lht }}"></span>
  <div class="dfi">
    <div class="dfs dfs-l">{%- if fd_util_left_icon != blank or fd_util_left_label != blank -%}{%- if fd_util_left_url != blank -%}<a href="{{ fd_util_left_url }}" class="dfu" target="{{ fd_util_left_target }}"{% if fd_util_left_target == '_blank' %} rel="noopener"{% endif %}>{%- else -%}<span class="dfu">{%- endif -%}{%- if fd_util_left_icon != blank -%}{%- case fd_util_left_icon -%}{%- when 'utility-1' -%}{{ gs.utility_icons[0].svg }}{%- when 'utility-2' -%}{{ gs.utility_icons[1].svg }}{%- else -%}{% render 'icon', icon: fd_util_left_icon, style: 'solid' %}{%- endcase -%}{%- endif -%}{%- if fd_util_left_label != blank -%}<span>{{ fd_util_left_label }}</span>{%- endif -%}{%- if fd_util_left_url != blank -%}</a>{%- else -%}</span>{%- endif -%}{%- endif -%}</div>
    <div class="dfc" style="max-width:min({{ content_max_px }}px, {{ content_max_vw }}vw)">
      <button class="dchv dfp" aria-label="Previous message" type="button">
        <svg viewBox="0 0 14 14" fill="none"><path d="M9 3L5 7l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span class="dfmw" data-dm-message><span style="color:{{ fd_bg_color }}">.</span></span>
      <button class="dchv dfn" aria-label="Next message" type="button">
        <svg viewBox="0 0 14 14" fill="none"><path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <div class="dfs dfs-r">{%- if fd_util_right_icon != blank or fd_util_right_label != blank -%}{%- if fd_util_right_url != blank -%}<a href="{{ fd_util_right_url }}" class="dfu" target="{{ fd_util_right_target }}"{% if fd_util_right_target == '_blank' %} rel="noopener"{% endif %}>{%- else -%}<span class="dfu">{%- endif -%}{%- if fd_util_right_icon != blank -%}{%- case fd_util_right_icon -%}{%- when 'utility-1' -%}{{ gs.utility_icons[0].svg }}{%- when 'utility-2' -%}{{ gs.utility_icons[1].svg }}{%- else -%}{% render 'icon', icon: fd_util_right_icon, style: 'solid' %}{%- endcase -%}{%- endif -%}{%- if fd_util_right_label != blank -%}<span>{{ fd_util_right_label }}</span>{%- endif -%}{%- if fd_util_right_url != blank -%}</a>{%- else -%}</span>{%- endif -%}{%- endif -%}</div>
  </div>
</div>

<link rel="preload" href="/cart.js" as="fetch" crossorigin>
<script src="{{ 'delivery-messaging.js' | asset_url }}" defer></script>
<script src="{{ 'dib-announcement-cycling.js' | asset_url }}" defer></script>

{%- endunless -%}

{% schema %}
{
  "name": "Delivery Announcement",
  "target": "section",
  "settings": []
}
{% endschema %}
