{{ 'dib-messages.css' | asset_url | stylesheet_tag }}
<style>
#{{ uid }} .dib-shipping-prices{display:flex;flex-wrap:wrap;align-items:center;justify-content:{{ shipping_prices_alignment_final }};gap:8px 12px;padding:8px 12px;font-size:14px;line-height:1.4;{% if shipping_prices_text_color_final != blank %}color:{{ shipping_prices_text_color_final }};{% endif %}{% if shipping_prices_bg_color_final != blank %}background-color:{{ shipping_prices_bg_color_final }};{% endif %}{% if shipping_prices_border_width_final > 0 %}border:{{ shipping_prices_border_width_final }}px solid {{ shipping_prices_border_color_final }};{% endif %}border-radius:{{ shipping_prices_border_radius_final }}px}
#{{ uid }} .dib-sp-item{display:flex;align-items:center;gap:6px;white-space:nowrap}
#{{ uid }} .dib-sp-icon{width:{{ shipping_prices_icon_size_final }}px;height:{{ shipping_prices_icon_size_final }}px;flex-shrink:0;display:inline-flex}
#{{ uid }} .dib-sp-divider{opacity:0.5}
</style>
<div id="{{ uid }}" class="dib-shipping-prices-block" style="text-align:{{ shipping_prices_alignment_final }};{% if shipping_prices_margin_top != 0 %}margin-top:{{ shipping_prices_margin_top }}px;{% endif %}{% if shipping_prices_margin_bottom != 0 %}margin-bottom:{{ shipping_prices_margin_bottom }}px;{% endif %}">
<div class="dib-shipping-prices" style="opacity:0;display:inline-flex">
{%- assign sp_needs_divider = false -%}
{%- if shipping_opt1_enabled_final -%}
