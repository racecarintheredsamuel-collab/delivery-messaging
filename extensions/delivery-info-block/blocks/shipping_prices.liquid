{%- assign sp_needs_divider = true -%}
{%- endif -%}
{%- if shipping_opt2_enabled_final -%}
{%- if sp_needs_divider -%}<span class="dib-sp-divider">{{ shipping_prices_divider_final }}</span>{%- endif -%}
<span class="dib-sp-item"><span class="dib-sp-icon" style="color:{{ shipping_prices_text_color_final }}">{% render 'icon', icon: shipping_opt2_icon_final, style: shipping_opt2_icon_style_final %}</span><span>{{ shipping_opt2_name_final }} {{ shipping_opt2_price_final }}{% if sp_opt2_time_display != blank %} &bull; {{ sp_opt2_time_display }}{% endif %}</span></span>
{%- assign sp_needs_divider = true -%}
{%- endif -%}
{%- if shipping_opt3_enabled_final -%}
{%- if sp_needs_divider -%}<span class="dib-sp-divider">{{ shipping_prices_divider_final }}</span>{%- endif -%}
<span class="dib-sp-item"><span class="dib-sp-icon" style="color:{{ shipping_prices_text_color_final }}">{% render 'icon', icon: shipping_opt3_icon_final, style: shipping_opt3_icon_style_final %}</span><span>{%- if shipping_opt3_mode_final == 'dynamic' and sp_cart_remaining > 0 -%}{{ sp_cart_remaining_display }} more for FREE{%- elsif shipping_opt3_mode_final == 'dynamic' and sp_cart_remaining <= 0 -%}FREE delivery unlocked!{%- else -%}Free over {{ sp_fd_threshold_display }}{%- endif -%}</span></span>
{%- endif -%}
</div>
</div>
